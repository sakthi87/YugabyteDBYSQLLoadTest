{
  "run_label": "index_and_fk",
  "run_description": "10 tables with ref_id indexes and FK chain. Per-op SELECT/INSERT/UPDATE/DELETE ramps 200/400/600 TPS. env: ${YB_ENV_LABEL}",
  "db": {
    "host": "${YB_HOST}",
    "port": "${YB_PORT}",
    "user": "${YB_USER}",
    "password": "${YB_PASSWORD}",
    "dbname": "${YB_DBNAME}"
  },
  "schema": {
    "create_db": true,
    "drop_db": true,
    "schema_sql_file": "scripts/scenarios/schema_index_fk.sql",
    "preload_sql_file": "scripts/scenarios/preload_10_tables.sql"
  },
  "reports": {
    "csv": true,
    "html": true
  },
  "server_metrics": {
    "tserver_urls": ["${YB_TSERVER_METRICS}"]
  },
  "phases": [
    {
      "name": "select",
      "type": "pgbench",
      "clients": 8,
      "jobs": 2,
      "log_transactions": true,
      "report_per_script": true,
      "script": "scripts/pgbench10/select.sql",
      "ramp": [
        { "duration_sec": 30, "target_tps": 200 },
        { "duration_sec": 30, "target_tps": 400 },
        { "duration_sec": 60, "target_tps": 600 }
      ]
    },
    {
      "name": "insert",
      "type": "pgbench",
      "clients": 8,
      "jobs": 2,
      "log_transactions": true,
      "report_per_script": true,
      "script": "scripts/pgbench10/insert.sql",
      "ramp": [
        { "duration_sec": 30, "target_tps": 200 },
        { "duration_sec": 30, "target_tps": 400 },
        { "duration_sec": 60, "target_tps": 600 }
      ]
    },
    {
      "name": "update",
      "type": "pgbench",
      "clients": 8,
      "jobs": 2,
      "log_transactions": true,
      "report_per_script": true,
      "script": "scripts/pgbench10/update.sql",
      "ramp": [
        { "duration_sec": 30, "target_tps": 200 },
        { "duration_sec": 30, "target_tps": 400 },
        { "duration_sec": 60, "target_tps": 600 }
      ]
    },
    {
      "name": "delete",
      "type": "pgbench",
      "clients": 8,
      "jobs": 2,
      "log_transactions": true,
      "report_per_script": true,
      "script": "scripts/pgbench10/delete.sql",
      "ramp": [
        { "duration_sec": 30, "target_tps": 200 },
        { "duration_sec": 30, "target_tps": 400 },
        { "duration_sec": 60, "target_tps": 600 }
      ]
    }
  ]
}
