{
  "run_label": "fk_production_capacity",
  "run_description": "Production capacity: 10 tables with FKs, no indexes. Max throughput for 60/120 sec with scaled clients. env: ${YB_ENV_LABEL}",
  "db": {
    "host": "${YB_HOST}",
    "port": "${YB_PORT}",
    "user": "${YB_USER}",
    "password": "${YB_PASSWORD}",
    "dbname": "${YB_DBNAME}"
  },
  "schema": {
    "create_db": true,
    "drop_db": true,
    "schema_sql_file": "../../../scripts/scenarios/schema_fk.sql",
    "preload_sql_file": "../../../scripts/scenarios/preload_10_tables.sql"
  },
  "reports": { "csv": true, "html": true },
  "server_metrics": {
    "tserver_urls": ["${YB_TSERVER_METRICS}"],
    "pg_stat_statements": true,
    "pg_stat_statements_interval_sec": 5
  },
  "phases": [
    { "name": "select", "type": "pgbench", "log_transactions": true, "report_per_script": true, "script": "../../../scripts/pgbench10/select.sql", "ramp": [{ "duration_sec": 60, "clients": 64, "jobs": 8 }, { "duration_sec": 120, "clients": 128, "jobs": 8 }, { "duration_sec": 120, "clients": 256, "jobs": 8 }] },
    { "name": "insert", "type": "pgbench", "log_transactions": true, "report_per_script": true, "script": "../../../scripts/pgbench10/insert.sql", "ramp": [{ "duration_sec": 60, "clients": 64, "jobs": 8 }, { "duration_sec": 120, "clients": 128, "jobs": 8 }, { "duration_sec": 120, "clients": 256, "jobs": 8 }] },
    { "name": "update", "type": "pgbench", "log_transactions": true, "report_per_script": true, "script": "../../../scripts/pgbench10/update.sql", "ramp": [{ "duration_sec": 60, "clients": 64, "jobs": 8 }, { "duration_sec": 120, "clients": 128, "jobs": 8 }, { "duration_sec": 120, "clients": 256, "jobs": 8 }] },
    { "name": "delete", "type": "pgbench", "log_transactions": true, "report_per_script": true, "script": "../../../scripts/pgbench10/delete.sql", "ramp": [{ "duration_sec": 60, "clients": 64, "jobs": 8 }, { "duration_sec": 120, "clients": 128, "jobs": 8 }, { "duration_sec": 120, "clients": 256, "jobs": 8 }] }
  ]
}
