{
  "run_label": "plain_transaction_count_stretch",
  "run_description": "Stretch Cluster transaction count: 10 tables, no indexes, no FKs. Fixed-record runs (50K/100K/200K tx). env: ${YB_ENV_LABEL}",
  "db": {
    "host": "${YB_HOST}",
    "port": "${YB_PORT}",
    "user": "${YB_USER}",
    "password": "${YB_PASSWORD}",
    "dbname": "${YB_DBNAME}"
  },
  "schema": {
    "create_db": true,
    "drop_db": true,
    "schema_sql_file": "../../../scripts/scenarios/schema_plain.sql",
    "preload_sql_file": "../../../scripts/scenarios/preload_10_tables.sql"
  },
  "reports": { "csv": true, "html": true },
  "server_metrics": {
    "tserver_urls": ["${YB_TSERVER_METRICS}"],
    "pg_stat_statements": true,
    "pg_stat_statements_interval_sec": 5
  },
  "phases": [
    { "name": "select", "type": "pgbench", "log_transactions": true, "report_per_script": true, "script": "../../../scripts/pgbench10/select.sql", "ramp": [{ "total_transactions": 50000, "clients": 32, "jobs": 4 }, { "total_transactions": 100000, "clients": 64, "jobs": 8 }, { "total_transactions": 200000, "clients": 128, "jobs": 8 }] },
    { "name": "insert", "type": "pgbench", "log_transactions": true, "report_per_script": true, "script": "../../../scripts/pgbench10/insert.sql", "ramp": [{ "total_transactions": 50000, "clients": 32, "jobs": 4 }, { "total_transactions": 100000, "clients": 64, "jobs": 8 }, { "total_transactions": 200000, "clients": 128, "jobs": 8 }] },
    { "name": "update", "type": "pgbench", "log_transactions": true, "report_per_script": true, "script": "../../../scripts/pgbench10/update.sql", "ramp": [{ "total_transactions": 50000, "clients": 32, "jobs": 4 }, { "total_transactions": 100000, "clients": 64, "jobs": 8 }, { "total_transactions": 200000, "clients": 128, "jobs": 8 }] },
    { "name": "delete", "type": "pgbench", "log_transactions": true, "report_per_script": true, "script": "../../../scripts/pgbench10/delete.sql", "ramp": [{ "total_transactions": 50000, "clients": 32, "jobs": 4 }, { "total_transactions": 100000, "clients": 64, "jobs": 8 }, { "total_transactions": 200000, "clients": 128, "jobs": 8 }] }
  ],
  "cluster": {
    "cluster_type": "stretch",
    "cluster_topology": "2c-2e-1onprem",
    "replication_mode": "none",
    "xcluster_enabled": false
  }
}
