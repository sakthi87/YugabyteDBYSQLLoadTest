{
  "db": {
    "host": "127.0.0.1",
    "port": 5434,
    "user": "yugabyte",
    "password": "",
    "dbname": "yb_load_test"
  },
  "schema": {
    "create_db": true,
    "drop_db": true,
    "schema_sql_file": "scripts/schema.sql",
    "preload_sql_file": "scripts/preload.sql"
  },
  "reports": {
    "csv": true,
    "html": true
  },
  "phases": [
    {
      "name": "mixed_oltp",
      "type": "pgbench",
      "clients": 8,
      "jobs": 2,
      "log_transactions": true,
      "mix": [
        { "script": "scripts/pgbench/select.sql", "weight": 60 },
        { "script": "scripts/pgbench/update.sql", "weight": 25 },
        { "script": "scripts/pgbench/insert.sql", "weight": 10 },
        { "script": "scripts/pgbench/delete.sql", "weight": 5 }
      ],
      "ramp": [
        { "duration_sec": 30, "target_tps": 200 },
        { "duration_sec": 30, "target_tps": 400 },
        { "duration_sec": 60, "target_tps": 600 }
      ]
    }
  ]
}
