{
  "run_label": "index_tps_validation",
  "run_description": "Validation TPS: Short run for script testing. 2 steps × 20 sec. env: ${YB_ENV_LABEL}",
  "db": {
    "host": "${YB_HOST}",
    "port": "${YB_PORT}",
    "user": "${YB_USER}",
    "password": "${YB_PASSWORD}",
    "dbname": "${YB_DBNAME}"
  },
  "schema": {
    "create_db": true,
    "drop_db": true,
    "schema_sql_file": "../../../scripts/scenarios/schema_index.sql",
    "preload_sql_file": "../../../scripts/scenarios/preload_10_tables.sql"
  },
  "reports": { "csv": true, "html": true },
  "server_metrics": {
    "tserver_urls": ["${YB_TSERVER_METRICS}"],
    "pg_stat_statements": true,
    "pg_stat_statements_interval_sec": 5
  },
  "phases": [
    { "name": "select", "type": "pgbench", "clients": 8, "jobs": 2, "log_transactions": true, "report_per_script": true, "script": "../../../scripts/pgbench10/select.sql", "ramp": [{ "duration_sec": 20, "target_tps": 200 }, { "duration_sec": 20, "target_tps": 400 }] },
    { "name": "insert", "type": "pgbench", "clients": 8, "jobs": 2, "log_transactions": true, "report_per_script": true, "script": "../../../scripts/pgbench10/insert.sql", "ramp": [{ "duration_sec": 20, "target_tps": 200 }, { "duration_sec": 20, "target_tps": 400 }] },
    { "name": "update", "type": "pgbench", "clients": 8, "jobs": 2, "log_transactions": true, "report_per_script": true, "script": "../../../scripts/pgbench10/update.sql", "ramp": [{ "duration_sec": 20, "target_tps": 200 }, { "duration_sec": 20, "target_tps": 400 }] },
    { "name": "delete", "type": "pgbench", "clients": 8, "jobs": 2, "log_transactions": true, "report_per_script": true, "script": "../../../scripts/pgbench10/delete.sql", "ramp": [{ "duration_sec": 20, "target_tps": 200 }, { "duration_sec": 20, "target_tps": 400 }] }
  ]
}
